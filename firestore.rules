rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@adobeing.com' ||
        request.auth.token.isAdmin == true
      );
    }

    // ── Public survey access (no login required) ──────────────────────────────
    // Must be declared before the catch-all /{subcollection}/{docId} below
    // so the more-specific path takes effect for unauthenticated respondents.
    match /users/{userId}/surveys/{surveyId} {
      // Anyone can read an Active survey to fill it out
      allow read:  if true;
      // Only the owner (or super admin) can create / update / delete surveys
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || isSuperAdmin());

      match /responses/{responseId} {
        // Anyone can submit a response
        allow create: if true;
        // Only the owner (or super admin) can read responses
        allow read:   if request.auth != null &&
                         (request.auth.uid == userId || isSuperAdmin());
      }
    }

    // ── Public appointment response (confirm / cancel / reschedule) ──────────
    match /users/{userId}/appointments/{appointmentId} {
      allow read: if true;
      // The URL (userId + appointmentId) acts as the shared secret — same model
      // as Google Forms / Calendly. Anyone with the link can respond.
      allow update: if true;
      allow write:  if request.auth != null &&
                       (request.auth.uid == userId || isSuperAdmin());
    }

    // ── Public patient intake form submissions ────────────────────────────────
    match /users/{userId}/patients/{patientId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
                                     (request.auth.uid == userId || isSuperAdmin());
    }

    // ── Per-user data (authenticated access only) ─────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read:        if isSuperAdmin();
      allow write:       if isSuperAdmin();

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read:        if isSuperAdmin();
      }
    }

    // ── Super admin data ──────────────────────────────────────────────────────
    // 'settings' is readable by any logged-in user (banking details for checkout)
    match /superadmin/settings {
      allow read: if request.auth != null;
    }
    match /superadmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Platform notifications (super admin → users) ───────────────────────
    match /notifications/{id} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ── Support messages (users → super admin) ────────────────────────────
    match /support_messages/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isSuperAdmin();
    }

    // ── Events ────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && resource.data.organizerUid == request.auth.uid;
      match /guests/{guestId} {
        allow read: if true;
        allow write: if request.auth != null
                     && get(/databases/$(database)/documents/events/$(eventId)).data.organizerUid == request.auth.uid;
      }
      match /tables/{tableId} {
        allow read: if true;
        allow write: if request.auth != null
                     && get(/databases/$(database)/documents/events/$(eventId)).data.organizerUid == request.auth.uid;
      }
    }
  }
}
